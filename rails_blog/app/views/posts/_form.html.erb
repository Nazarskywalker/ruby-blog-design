<div class="form-container">
  <h2><%= title %></h2>

  <% if post %>
    <div class="edit-mode-info">
      <p>Ви редагуєте існуючий пост.</p>
    </div>
  <% end %>

  <%= form_with url: action, method: method_name, local: true, multipart: true, class: "post-form" do |form| %>
    <div class="form-group">
      <%= form.label :title, "Назва поста" %>
      <%= form.text_field :title, value: post ? post[:title] : "", required: true, placeholder: "Введіть назву" %>
    </div>

    <div class="form-group">
      <%= form.label :content, "Текст поста" %>
      <%= form.text_area :content, value: post ? post[:content] : "", rows: 8, required: true, placeholder: "Напишіть текст поста" %>
    </div>

    <div class="form-group">
      <%= form.label :image, "Зображення" %>
      <%= form.file_field :image, accept: "image/*" %>
      <% if post && post[:image] %>
        <div class="current-image">
          <p>Поточне зображення:</p>
          <%= image_tag post[:image], alt: post[:title], style: "max-width: 240px; border-radius: 8px;" %>
        </div>
      <% end %>
    </div>

    <div class="form-actions">
      <%= form.submit post ? "Зберегти зміни" : "Створити пост", class: "btn btn-primary" %>
      <%= link_to "Назад", manage_posts_path, class: "btn btn-secondary" %>
    </div>
  <% end %>
</div>
