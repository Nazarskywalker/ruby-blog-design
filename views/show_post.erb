<div class="post-detail">
    <article class="post-full">
        <h2><%= post[:title] %></h2>
        <div class="post-meta">
            <p>Створено: <%= post[:created_at] %></p>
            <% if post[:updated_at] %>
                <p>Оновлено: <%= post[:updated_at] %></p>
            <% end %>
        </div>
        <% if post[:image] %>
            <div class="post-image-full">
                <img src="<%= post[:image] %>" alt="<%= post[:title] %>" loading="lazy">
            </div>
        <% end %>
        <div class="post-content">
            <%= post[:content].gsub("\n", "<br>") %>
        </div>
        <div class="post-actions">
            <a href="/" class="btn btn-secondary">← Назад до всіх постів</a>
        </div>
    </article>
</div>
