<div class="manage-container">
    <h2>Управління постами</h2>
    
    <div class="actions-header">
        <a href="/posts/new" class="btn btn-primary">Створити новий пост</a>
    </div>
    
    <% if posts.empty? %>
        <div class="no-posts-manage">
            <p>Постів ще немає. Створіть перший пост!</p>
        </div>
    <% else %>
        <div class="posts-list">
            <h3>Ваші пости:</h3>
            <% posts.each do |post| %>
                <div class="post-item">
                    <div class="post-info">
                        <h4><a href="/posts/<%= post[:id] %>/edit" class="post-title-link"><%= post[:title] %></a></h4>
                        <p class="post-meta">
                            Створено: <%= post[:created_at] %>
                            <% if post[:updated_at] %>
                                | Оновлено: <%= post[:updated_at] %>
                            <% end %>
                        </p>
                        <% if post[:image] %>
                            <div class="post-thumb">
                                <img src="<%= post[:image] %>" alt="<%= post[:title] %>" loading="lazy">
                            </div>
                        <% end %>
                        <p class="post-excerpt"><%= post[:content][0..150] %>...</p>
                    </div>
                    <div class="post-actions">
                        <a href="/posts/<%= post[:id] %>/edit" class="btn btn-warning">Редагувати</a>
                        <form action="/posts/<%= post[:id] %>" method="post" style="display: inline;">
                            <input type="hidden" name="_method" value="delete">
                            <button type="submit" class="btn btn-danger" onclick="return confirm('Ви впевнені, що хочете видалити цей пост?')">Видалити</button>
                        </form>
                        <a href="/posts/<%= post[:id] %>" class="btn btn-info" target="_blank">Переглянути</a>
                    </div>
                </div>
            <% end %>
        </div>
    <% end %>
</div>
